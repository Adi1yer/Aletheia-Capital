# Alpaca Paper Trading API (required for --execute)
# Get keys from https://app.alpaca.markets/ (Paper Trading)
ALPACA_API_KEY=your-alpaca-api-key-id
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
# For live trading: use live keys and APCA_BASE_URL=https://api.alpaca.markets/v2

# Optional: isolated paper account for biotech catalyst scanner only (see biotech_catalyst_scan.py)
BIOTECH_ALPACA_API_KEY=
BIOTECH_ALPACA_SECRET_KEY=

# Biotech catalyst scanner: comma-separated tickers overrides config/biotech_watchlist.txt
# BIOTECH_TICKERS=MRNA,VRTX
# Readout window (days): trials with primary/completion in [today - grace, today + forward]
# BIOTECH_READOUT_FORWARD_DAYS=120
# BIOTECH_READOUT_PAST_GRACE_DAYS=45

# Scan cache: 0 = never auto-delete weekly run folders (default). Set >0 only if you want pruning.
SCAN_CACHE_KEEP_WEEKS=0

# Free LLM APIs (use as needed)
# DeepSeek – when set, agents use cloud LLM (enables scaling to 100+ tickers)
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI (if using free tier or credits)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (if using free tier)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Groq (free tier available)
GROQ_API_KEY=your-groq-api-key

# Alpha Vantage (free tier - 5 calls/min, 500/day)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Finnhub (free tier: 60 calls/min) – insider transactions + analyst recommendations
FINNHUB_API_KEY=your-finnhub-api-key

# Congressional trades (optional) – FinBrain House Trades API; Finnhub also supports congressional when key above is set
CONGRESSIONAL_API_KEY=your-finbrain-api-key

# Crypto pipeline (optional) – set CRYPTO_ENABLED=true for --crypto; CoinGecko free tier works without key
CRYPTO_ENABLED=false
COINGECKO_API_KEY=

# Email (for weekly run summary to aditya.iyer@gmail.com)
# Gmail: use App Password from Google Account → Security → App passwords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password
RECIPIENT_EMAIL=aditya.iyer@gmail.com

# Configuration
TRADING_FREQUENCY=weekly
LOG_LEVEL=INFO
ENVIRONMENT=production

